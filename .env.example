# ── Required for AI analysis ──────────────────────────────────────────────────
# Without this the scanner runs in demo mode (technical checks still work).
ANTHROPIC_API_KEY=

# ── Required for scan storage and rate limiting ───────────────────────────────
# Without these, no results are saved and rate limiting is disabled.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Required for IP hashing (rate limit + GDPR pseudonymisation) ──────────────
# 32+ byte hex secret. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Per CJEU Breyer + EDPB Guidelines 01/2025, hashed IP is still pseudonymised
# personal data — pepper is required best practice (HMAC-SHA256, not plain SHA-256).
# In production this MUST be set or the app will throw on boot. See docs/strategy/research/04-legal-eu-ai-act-gdpr.md § 4.3.
IP_HASH_PEPPER=

# ── Hard daily scan limit (default: 200) ──────────────────────────────────────
# Total scans allowed per calendar day across all users.
# Requires Supabase to be configured. Ignored without it.
DAILY_SCAN_LIMIT=200

# ── Optional: Firecrawl — improves Claude analysis and API scoring ─────────────
# Used to scrape JS-rendered pages (homepage content + developer portals).
# Without this, only static HTML and OpenAPI specs are analysed.
FIRECRAWL_API_KEY=

# ── Optional: Exa — semantic search for developer portal discovery ─────────────
# Finds developer portals at non-standard locations (e.g. developer.fortnox.se)
# via neural/semantic search when path probing and npm/GitHub signals fail.
# Without this, only npm, GitHub SDK repos, and llms.txt subdomain probes are used.
# Get a key at exa.ai — ~$0.007 per scan.
EXA_API_KEY=

# Optional: local/testing bypass for Swedish-company gate.
# Set to 1 (or true) only in non-production environments.
BYPASS_SWEDISH_CHECK=
