# ── Required for AI analysis ──────────────────────────────────────────────────
# Without this the scanner runs in demo mode (technical checks still work).
ANTHROPIC_API_KEY=

# ── Required for scan storage and rate limiting ───────────────────────────────
# Without these, no results are saved and rate limiting is disabled.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Optional: Firecrawl — improves Claude analysis and API scoring ─────────────
# Used to scrape JS-rendered pages (homepage content + developer portals).
# Without this, only static HTML and OpenAPI specs are analysed.
FIRECRAWL_API_KEY=
